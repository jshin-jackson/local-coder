# Path to the GGUF model file (relative to project root or absolute)
MODEL_PATH=../models/gpt-oss-20b-Coding-Distill-Q4_K_M.gguf

# Number of layers to offload to Metal GPU (-1 = all layers)
N_GPU_LAYERS=-1

# Context window size (tokens)
N_CTX=4096

# Number of threads for CPU inference
N_THREADS=8

# Host and port for the backend server
HOST=0.0.0.0
PORT=8000
